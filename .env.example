# Database (Neon)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Auth.js
AUTH_SECRET=  # Generate with: npx auth secret
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=https://your-app.vercel.app  # Production URL

# LLM Providers
CLAUDE_API_KEY=  # Anthropic API key (use CLAUDE_API_KEY to avoid shell conflicts)
GOOGLE_AI_API_KEY=  # Google AI / Gemini

# Flight Search
DUFFEL_API_KEY=  # Duffel.com API key
SERPAPI_API_KEY=  # SerpApi for Google Flights

# Encryption
ENCRYPTION_KEY=  # Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Integrations (future)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# FLIGHTAWARE_API_KEY=
# PREDICTHQ_API_KEY=
